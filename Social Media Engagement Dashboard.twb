      <aliases enabled='yes' />
      <column caption='total engagement' datatype='integer' name='[Calculation_1165545054654464]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[likes] + [comments] + [shares] + [saves]' />
      </column>
      <column caption='Engagement per Impression' datatype='real' name='[Calculation_1165545054904321]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([likes] + [comments] + [shares] + [saves]) / [impressions]' />
      </column>
      <column caption='Posting Hour Group' datatype='string' name='[Calculation_1165545055051778]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [hour] &lt; 12 THEN &quot;Morning&quot;&#13;&#10;ELSEIF [hour] &lt; 17 THEN &quot;Afternoon&quot;&#13;&#10;ELSE &quot;Evening&quot;&#13;&#10;END' />
      </column>
